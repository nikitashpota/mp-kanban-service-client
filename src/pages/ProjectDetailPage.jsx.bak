import { useState, useEffect, useRef } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import {
  getProject, uploadPhotos, deletePhoto, setMainPhoto,
  uploadTep, addContact, updateContact, deleteContact,
  deleteProject, photoUrl
} from '../api/client';
import { useAuth } from '../context/AuthContext';
import PhotoGallery from '../components/PhotoGallery';

function fmt(v, dec = 0) {
  if (!v && v !== 0) return '—';
  return Number(v).toLocaleString('ru-RU', { maximumFractionDigits: dec });
}

const STAGE_LABELS = { АПР: 'АПР — Архитектурно-планировочное решение', П: 'П — Проект', РД: 'РД — Рабочая документация', 'Завершён': 'Завершён' };

export default function ProjectDetailPage() {
  const { id } = useParams();
  const nav = useNavigate();
  const { isAdmin } = useAuth();

  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(true);
  const [msg, setMsg] = useState(null);

  // Uploading states
  const [uploadingPhoto, setUploadingPhoto] = useState(false);
  const [uploadingTep, setUploadingTep] = useState(false);

  // Contact edit
  const [contactModal, setContactModal] = useState(null); // null | {mode:'add'|'edit', data}
  const [contactForm, setContactForm] = useState({ legal_entity: '', position: '', person_name: '', phone: '' });

  const photoInputRef = useRef();
  const tepInputRef = useRef();

  const load = () => {
    setLoading(true);
    getProject(id).then(setData).finally(() => setLoading(false));
  };

  useEffect(() => { load(); }, [id]);

  const flash = (text, type = 'success') => {
    setMsg({ text, type });
    setTimeout(() => setMsg(null), 3000);
  };

  // ── Photos ──────────────────────────────────────────────────
  const handlePhotoUpload = async (e) => {
    const files = Array.from(e.target.files);
    if (!files.length) return;
    setUploadingPhoto(true);
    try {
      await uploadPhotos(id, files);
      flash('Фотографии загружены');
      load();
    } catch { flash('Ошибка загрузки фото', 'error'); }
    finally { setUploadingPhoto(false); e.target.value = ''; }
  };

  const handleDeletePhoto = async (photoId) => {
    if (!confirm('Удалить фото?')) return;
    try {
      await deletePhoto(id, photoId);
      flash('Фото удалено');
      load();
    } catch { flash('Ошибка', 'error'); }
  };

  const handleSetMain = async (photoId) => {
    try {
      await setMainPhoto(id, photoId);
      flash('Главное фото обновлено');
      load();
    } catch { flash('Ошибка', 'error'); }
  };

  // ── ТЭП ─────────────────────────────────────────────────────
  const handleTepUpload = async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    setUploadingTep(true);
    try {
      const result = await uploadTep(id, file);
      flash(result.message);
      load();
    } catch (err) {
      flash(err.response?.data?.error || 'Ошибка импорта', 'error');
    } finally { setUploadingTep(false); e.target.value = ''; }
  };

  // ── Contacts ─────────────────────────────────────────────────
  const openContactAdd = () => {
    setContactForm({ legal_entity: '', position: '', person_name: '', phone: '' });
    setContactModal({ mode: 'add' });
  };
  const openContactEdit = (c) => {
    setContactForm({ legal_entity: c.legal_entity || '', position: c.position || '', person_name: c.person_name || '', phone: c.phone || '' });
    setContactModal({ mode: 'edit', id: c.id });
  };
  const saveContact = async () => {
    try {
      if (contactModal.mode === 'add') {
        await addContact(id, contactForm);
        flash('Контакт добавлен');
      } else {
        await updateContact(id, contactModal.id, contactForm);
        flash('Контакт обновлён');
      }
      setContactModal(null);
      load();
    } catch { flash('Ошибка сохранения контакта', 'error'); }
  };
  const handleDeleteContact = async (contactId) => {
    if (!confirm('Удалить контакт?')) return;
    try { await deleteContact(id, contactId); flash('Удалено'); load(); }
    catch { flash('Ошибка', 'error'); }
  };

  const handleDelete = async () => {
    if (!confirm(`Удалить объект "${data.project.name}"? Отменить нельзя.`)) return;
    try { await deleteProject(id); nav('/projects'); }
    catch { flash('Ошибка удаления', 'error'); }
  };

  if (loading) return <div className="loading-center"><div className="spinner" /></div>;
  if (!data) return <div className="empty-state"><div className="empty-state__icon">❌</div><div>Объект не найден</div></div>;

  const { project, photos, contacts, tep } = data;
  const stageCls = ['АПР', 'П', 'РД', 'Завершён'].includes(project.stage)
    ? `stage-badge--${project.stage}` : 'stage-badge--default';

  return (
    <>
      {msg && <div className={`alert alert--${msg.type}`} style={{ marginBottom: 16 }}>{msg.text}</div>}

      {/* ── Header card ── */}
      <div className="project-header">
        <div className="project-header__top">
          {/* Main photo */}
          <div className="project-header__main-photo">
            {project.main_photo
              ? <img src={photoUrl(project.main_photo)} alt={project.name} />
              : <div style={{ width: '100%', height: '100%', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 56, background: '#e8e8e8' }}>🏢</div>
            }
          </div>

          {/* Info */}
          <div className="project-header__info">
            <div style={{ display: 'flex', alignItems: 'flex-start', justifyContent: 'space-between', gap: 12 }}>
              <div>
                <div className="project-header__name">{project.name}</div>
                {project.address && <div className="project-header__address">📍 {project.address}</div>}
              </div>
              {isAdmin && (
                <div style={{ display: 'flex', gap: 8, flexShrink: 0 }}>
                  <button className="btn btn--secondary btn--sm" onClick={() => nav(`/admin/projects/${id}/edit`)}>✏️ Редактировать</button>
                  <button className="btn btn--danger btn--sm" onClick={handleDelete}>🗑 Удалить</button>
                </div>
              )}
            </div>

            <div style={{ display: 'flex', gap: 8, marginBottom: 16, flexWrap: 'wrap' }}>
              {project.stage && <span className={`stage-badge ${stageCls}`}>{STAGE_LABELS[project.stage] || project.stage}</span>}
              {project.completion_date && (
                <span style={{ fontSize: 12, color: 'var(--accent)', fontWeight: 500 }}>
                  📅 Срок: {project.completion_date}
                </span>
              )}
            </div>

            <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '2px 20px' }}>
              {project.inn && <div className="info-row"><span className="info-row__label">ИНН</span><span className="info-row__value">{project.inn}</span></div>}
              {project.kpp && <div className="info-row"><span className="info-row__label">КПП</span><span className="info-row__value">{project.kpp}</span></div>}
              {project.gip_name && <div className="info-row"><span className="info-row__label">ГИП</span><span className="info-row__value">{project.gip_name}</span></div>}
              {project.gip_phone && <div className="info-row"><span className="info-row__label">Тел. ГИП</span><span className="info-row__value">{project.gip_phone}</span></div>}
              {project.floors_above != null && <div className="info-row"><span className="info-row__label">Этажей</span><span className="info-row__value">{project.floors_above} надз. / {project.floors_below ?? 0} подз.</span></div>}
              {project.height && <div className="info-row"><span className="info-row__label">Высота</span><span className="info-row__value">{fmt(project.height, 1)} м</span></div>}
            </div>

            {project.description && (
              <div style={{ marginTop: 12, fontSize: 13, color: 'var(--text-secondary)', lineHeight: 1.6 }}>
                {project.description}
              </div>
            )}
          </div>
        </div>

        {/* Metrics row */}
        <div className="metrics-row">
          <div className="metric-box">
            <div className="metric-box__icon">📐</div>
            <div className="metric-box__value">{fmt(project.area_total)}</div>
            <div className="metric-box__unit">м²</div>
            <div className="metric-box__label">Общая площадь</div>
          </div>
          <div className="metric-box">
            <div className="metric-box__icon">🏗</div>
            <div className="metric-box__value">{fmt(project.area_building)}</div>
            <div className="metric-box__unit">м²</div>
            <div className="metric-box__label">Площадь застройки</div>
          </div>
          <div className="metric-box">
            <div className="metric-box__icon">⬇️</div>
            <div className="metric-box__value">{fmt(project.area_underground)}</div>
            <div className="metric-box__unit">м²</div>
            <div className="metric-box__label">Подземная часть</div>
          </div>
          <div className="metric-box">
            <div className="metric-box__icon">🏢</div>
            <div className="metric-box__value">{project.floors_above ?? '—'}</div>
            <div className="metric-box__unit">эт.</div>
            <div className="metric-box__label">Этажей надземных</div>
          </div>
        </div>

        {project.completion_date && (
          <div className="completion-bar">
            🗓 Дата завершения проектирования: {project.completion_date}
          </div>
        )}
      </div>

      {/* ── Photo Gallery ── */}
      <PhotoGallery photos={photos} />

      {/* ── Admin photo upload ── */}
      {isAdmin && (
        <div className="section-card" style={{ marginBottom: 20 }}>
          <div className="section-card__header">
            📤 Управление фотографиями
          </div>
          <div style={{ padding: 20 }}>
            <input ref={photoInputRef} type="file" accept="image/*" multiple style={{ display: 'none' }} onChange={handlePhotoUpload} />
            <div className="upload-zone" onClick={() => photoInputRef.current.click()}>
              <div className="upload-zone__icon">{uploadingPhoto ? '⏳' : '🖼'}</div>
              <div className="upload-zone__text">{uploadingPhoto ? 'Загружаю...' : 'Нажмите для загрузки фотографий'}</div>
              <div className="upload-zone__sub">JPG, PNG, WebP · до 20 МБ на файл</div>
            </div>
            {photos.length > 0 && (
              <div style={{ marginTop: 14, display: 'flex', gap: 10, flexWrap: 'wrap' }}>
                {photos.map(ph => (
                  <div key={ph.id} style={{ position: 'relative' }}>
                    <img src={photoUrl(ph.filename)} alt="" style={{ width: 100, height: 70, objectFit: 'cover', borderRadius: 6, border: ph.filename === project.main_photo ? '2px solid var(--accent)' : '2px solid transparent' }} />
                    <div style={{ position: 'absolute', top: 2, right: 2, display: 'flex', gap: 3 }}>
                      <button className="btn btn--sm" style={{ padding: '2px 5px', fontSize: 10, background: 'rgba(255,255,255,0.9)' }} onClick={() => handleSetMain(ph.id)} title="Сделать главным">⭐</button>
                      <button className="btn btn--danger btn--sm" style={{ padding: '2px 5px', fontSize: 10 }} onClick={() => handleDeletePhoto(ph.id)} title="Удалить">✕</button>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      )}

      {/* ── Contacts table ── */}
      <div className="section-card" style={{ marginBottom: 20 }}>
        <div className="section-card__header">
          👥 Ответственные лица
          {isAdmin && <button className="btn btn--primary btn--sm" onClick={openContactAdd}>➕ Добавить</button>}
        </div>
        <div className="table-wrap">
          {contacts.length === 0 ? (
            <div className="empty-state" style={{ padding: '24px 20px' }}>
              <div className="empty-state__sub">Контакты не добавлены</div>
            </div>
          ) : (
            <table>
              <thead>
                <tr>
                  <th>Юр. лицо</th>
                  <th>Должность</th>
                  <th>Ф.И.О. ответственного</th>
                  <th>Контакты</th>
                  {isAdmin && <th style={{ width: 80 }}></th>}
                </tr>
              </thead>
              <tbody>
                {contacts.map(c => (
                  <tr key={c.id}>
                    <td style={{ fontWeight: 500 }}>{c.legal_entity || '—'}</td>
                    <td>{c.position || '—'}</td>
                    <td>{c.person_name || '—'}</td>
                    <td>{c.phone || '—'}</td>
                    {isAdmin && (
                      <td>
                        <div style={{ display: 'flex', gap: 4 }}>
                          <button className="btn btn--secondary btn--sm btn--icon" onClick={() => openContactEdit(c)}>✏️</button>
                          <button className="btn btn--danger btn--sm btn--icon" onClick={() => handleDeleteContact(c.id)}>🗑</button>
                        </div>
                      </td>
                    )}
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>
      </div>

      {/* ── ТЭП table ── */}
      <div className="section-card" style={{ marginBottom: 20 }}>
        <div className="section-card__header">
          📊 Технико-экономические показатели
          {isAdmin && (
            <div style={{ display: 'flex', gap: 8, alignItems: 'center' }}>
              <span style={{ fontSize: 12, color: 'var(--text-secondary)' }}>XLSX: три колонки — Показатель, Значение, Ед.изм.</span>
              <input ref={tepInputRef} type="file" accept=".xlsx,.xls" style={{ display: 'none' }} onChange={handleTepUpload} />
              <button className="btn btn--primary btn--sm" onClick={() => tepInputRef.current.click()} disabled={uploadingTep}>
                {uploadingTep ? '⏳ Импорт...' : '📥 Загрузить XLSX'}
              </button>
            </div>
          )}
        </div>

        {tep.length === 0 ? (
          <div className="empty-state" style={{ padding: '32px 20px' }}>
            <div className="empty-state__icon">📊</div>
            <div className="empty-state__text">ТЭП не загружены</div>
            {isAdmin && <div className="empty-state__sub">Загрузите XLSX-файл с тремя колонками: Показатель, Значение, Ед. изм.</div>}
          </div>
        ) : (
          <div className="table-wrap">
            <table>
              <thead>
                <tr>
                  <th style={{ width: 40 }}>№</th>
                  <th>Наименование показателя</th>
                  <th style={{ textAlign: 'right' }}>Значение</th>
                  <th>Ед. измерения</th>
                </tr>
              </thead>
              <tbody>
                {tep.map((row, i) => (
                  <tr key={row.id}>
                    <td style={{ color: 'var(--text-light)', fontSize: 12 }}>{i + 1}</td>
                    <td>{row.parameter_name}</td>
                    <td style={{ textAlign: 'right', fontWeight: 600 }}>{row.value}</td>
                    <td style={{ color: 'var(--text-secondary)' }}>{row.unit}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

      {/* ── Contact Modal ── */}
      {contactModal && (
        <div className="modal-overlay" onClick={() => setContactModal(null)}>
          <div className="modal" onClick={e => e.stopPropagation()}>
            <div className="modal__header">
              <span className="modal__title">{contactModal.mode === 'add' ? 'Добавить контакт' : 'Редактировать контакт'}</span>
              <button className="btn btn--secondary btn--sm btn--icon" onClick={() => setContactModal(null)}>✕</button>
            </div>
            <div className="modal__body">
              <div className="form-group">
                <label className="form-label">Юр. лицо</label>
                <input className="form-input" value={contactForm.legal_entity} onChange={e => setContactForm(p => ({ ...p, legal_entity: e.target.value }))} />
              </div>
              <div className="form-group">
                <label className="form-label">Должность</label>
                <input className="form-input" value={contactForm.position} onChange={e => setContactForm(p => ({ ...p, position: e.target.value }))} />
              </div>
              <div className="form-group">
                <label className="form-label">Ф.И.О.</label>
                <input className="form-input" value={contactForm.person_name} onChange={e => setContactForm(p => ({ ...p, person_name: e.target.value }))} />
              </div>
              <div className="form-group">
                <label className="form-label">Телефон</label>
                <input className="form-input" placeholder="7 9XX XXX-XX-XX" value={contactForm.phone} onChange={e => setContactForm(p => ({ ...p, phone: e.target.value }))} />
              </div>
            </div>
            <div className="modal__footer">
              <button className="btn btn--secondary" onClick={() => setContactModal(null)}>Отмена</button>
              <button className="btn btn--primary" onClick={saveContact}>Сохранить</button>
            </div>
          </div>
        </div>
      )}
    </>
  );
}
